#!/bin/bash
# This file is used to fix the compile_commands.json file path for MQTTManager so that the
# host computer IDE can find associated libraries. Copy this file to /MQTTManager/fix_compile_commands_path.sh
# and it will be automatically sourced when building MQTTManager.
sed -i "s|/MQTTManager/|/home/tim/NSPanelManager/docker/MQTTManager/|g" compile_commands.json
